<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Startsida</title>
</head>
<body>

    <nav>
        <a href="/">Startsida</a> |
        <a href="/add">Lägg till kurs</a> |
        <a href="/about">Om sidan</a>
    </nav>

    <h1>Samtliga valda kurser</h1>

    <ul>
        <% if (courses && courses.length > 0) { %>
            <% courses.forEach(course => { %>
                <li><%= course.courseName %> (<%= course.courseCode %>) - <%= course.progression %></li>
            <% }) %>
        <% } else { %>
            <li>Inga kurser tillagda än.</li>
        <% } %>
    </ul>
    
</body>
</html>