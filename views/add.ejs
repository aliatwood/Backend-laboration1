<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kurstilläggning</title>
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="icon" href="/pictures/favicon.ico" type="image/ico">
</head>
<body>
    <nav>
        <a href="/">Startsida</a> |
        <a href="/add">Lägg till kurs</a> |
        <a href="/about">Om sidan</a>
    </nav>

    <h1>Lägg till kurser</h1>

    <main>
        <div class="form">
            <form action="/add" method="POST">
                <input type="text" id="kurskod" name="kurskod" placeholder="Kurskod">
                <input type="text" id="kursnamn" name="kursnamn" placeholder="Kursnamn">
                <input type="text" id="kursplan" name="kursplan" placeholder="Kursplan">
                <input type="text" id="kursprogression" name="kursprogression" placeholder="Kursprogression">

                <button class="form-btn">Skicka</button>

                <% if (error) { %>
                    <p class="error"><%= error %></p>
                <% } %>
            </form>
        </div>
    </main>

    <script>
        const links = document.querySelectorAll("nav a");
        links.forEach(link => {
            if (link.href === window.location.href) {
                link.classList.add("active");
            }
        });
    </script>

    <footer>
        © All rights reserved
    </footer>
    
</body>
</html>